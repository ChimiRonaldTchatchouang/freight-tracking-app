    "helmet": "7.1.0",
    "jsonwebtoken": "9.0.2",
    "nodemailer": "6.9.7",
    "pdfkit": "0.13.0",
    "qrcode": "1.5.3",
    "socket.io": "4.7.2",
    "winston": "3.11.0",
    "zod": "3.22.4"
  },
  "devDependencies": {
    "@types/express": "4.17.17",
    "@types/jest": "29.5.3",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^20.5.0",
    "@typescript-eslint/eslint-plugin": "6.4.0",
    "@typescript-eslint/parser": "6.4.0",
    "eslint": "8.47.0",
    "jest": "29.7.0",
    "nodemon": "3.0.1",
    "prisma": "5.8.0",
    "supertest": "6.3.3",
    "ts-jest": "29.1.1",
    "ts-node": "10.9.1",
    "typescript": "5.2.2"
