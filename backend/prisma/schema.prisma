generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String    @id @default(cuid())
  email     String    @unique
  password  String
  name      String?
  role      String    @default("representative")
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
}

model Boat {
  id               String    @id @default(cuid())
  name             String
  imoNumber        String    @unique
  capacityKg       Int
  portDeparture    String?
  portArrival      String?
  status           String    @default("en_equipement")
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
  
  expeditions      Expedition[]

  @@index([status])
}

model Vehicle {
  id               String    @id @default(cuid())
  registrationPlate String   @unique
  type             String
  weightEmptyKg    Int
  capacityKg       Int
  status           String    @default("disponible")
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
  
  expeditions      ExpeditionVehicle[]

  @@index([status, type])
}

model Expedition {
  id                    String    @id @default(cuid())
  boatId                String
  boat                  Boat      @relation(fields: [boatId], references: [id])
  trackingCode          String    @unique
  
  shipperName           String
  shipperEmail          String
  shipperPhone          String
  shipperAddress        String
  shipperCity           String
  shipperPostalCode     String
  
  receiverName          String
  receiverEmail         String
  receiverAddress       String
  receiverCity          String
  receiverPostalCode    String
  
  cargoDescription      String
  cargoWeightKg         Int
  cargoLengthCm         Int
  cargoHeightCm         Int
  cargoWidthCm          Int
  isFragile             Boolean   @default(false)
  requiresTemperature   Boolean   @default(false)
  temperatureCelsius    Int?
  specialInstructions   String?
  
  status                String    @default("creee")
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt
  
  vehicles              ExpeditionVehicle[]
  statusHistory         ExpeditionStatusHistory[]

  @@index([trackingCode])
  @@index([boatId])
  @@index([status])
}

model ExpeditionVehicle {
  id            String    @id @default(cuid())
  expeditionId  String
  vehicleId     String
  
  expedition    Expedition @relation(fields: [expeditionId], references: [id], onDelete: Cascade)
  vehicle       Vehicle   @relation(fields: [vehicleId], references: [id])
  
  @@unique([expeditionId, vehicleId])
}

model ExpeditionStatusHistory {
  id            String    @id @default(cuid())
  expeditionId  String
  oldStatus     String?
  newStatus     String
  changedAt     DateTime  @default(now())
  changedBy     String?
  notes         String?
  
  expedition    Expedition @relation(fields: [expeditionId], references: [id], onDelete: Cascade)

  @@index([expeditionId])
}

model Configuration {
  id    String  @id @default(cuid())
  key   String  @unique
  value String
}
